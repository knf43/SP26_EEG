# ---- main ---------------------------------------------------
main <- function(data_dir = DATA_DIR) {
  files <- dir_ls(data_dir, glob = "*StressLearning2025*.csv")
  if (length(files) == 0) stop("No CSVs found in ", data_dir)
  message("Loading ", length(files), " file(s)...")

  long <- load_all(files) |> clean_rt()

  message("  Total trials: ", nrow(long))
  message("  Participants: ",
          paste(sort(unique(long$participant)), collapse = ", "))

  by_pp        <- summary_pp(long)
  by_grp       <- summary_group(long)
  by_grp_cond  <- summary_group(long, "cond_name")
  by_grp_vstr  <- summary_group(long, "verb_stress")
  by_grp_full  <- summary_group(long, c("verb_stress", "suffix_tense"))
  by_grp_match <- summary_group(long, "verb_match")
  by_grp_train <- summary_group(filter(long, phase == "training"),
                                c("stress_unstress", "present_past"))
  by_grp_train_cond <- summary_group(filter(long, phase == "training"), "cond_name")

  xlsx_path <- path(OUTPUT_DIR, "behavioral_summary.xlsx")
  write.xlsx(
    list(
      trial_long                     = long,
      participant_x_phase            = by_pp,
      group_x_phase                  = by_grp,
      group_x_phase_x_cond           = by_grp_cond,
      group_x_phase_x_vstress        = by_grp_vstr,
      group_x_phase_x_vstress_x_suff = by_grp_full,
      group_x_phase_x_vmatch         = by_grp_match,
      training_breakdown             = by_grp_train,
      training_by_cond               = by_grp_train_cond,
      cond_legend_prepost            = COND_LEGEND_PREPOST,
      cond_legend_training           = COND_LEGEND_TRAINING
    ),
    xlsx_path, overwrite = TRUE
  )

  plot_pre_post(long,            path(OUTPUT_DIR, "fig1_pre_post_by_group.png"))
  plot_rt_comparison(long,       path(OUTPUT_DIR, "fig2_rt_comparison.png"))
  plot_training_curve(long,      path(OUTPUT_DIR, "fig3_training_curve.png"))
  plot_condition_letter(long,    path(OUTPUT_DIR, "fig4_condition.png"))
  plot_training_condition(long,  path(OUTPUT_DIR, "fig5_training_condition.png"))

  message("\nWrote: ", xlsx_path)
  cat("\n--- Per-participant × phase ---\n");                 print(by_pp)
  cat("\n--- Group × phase (overall) ---\n");                 print(by_grp)
  cat("\n--- Group × phase × condition ---\n");               print(by_grp_cond)
  cat("\n--- Training: group × condition ---\n");             print(by_grp_train_cond)

  invisible(list(
    long = long, by_pp = by_pp, by_grp = by_grp,
    by_grp_cond = by_grp_cond, by_grp_train_cond = by_grp_train_cond,
    cond_legend_prepost = COND_LEGEND_PREPOST,
    cond_legend_training = COND_LEGEND_TRAINING
  ))
}

res <- main()
