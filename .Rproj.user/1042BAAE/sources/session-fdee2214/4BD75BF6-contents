make_nmc_row <- function(model_label, effect_label, cmp) {
  data.frame(
    model  = model_label,
    effect = effect_label,
    chisq  = round(cmp$Chisq[2], 2),
    df     = cmp$Df[2],
    p      = signif(cmp$`Pr(>Chisq)`[2], 3)
  )
}

get_fixed <- function(mod, label) {
  tidy(mod, effects = "fixed", conf.int = TRUE) |>
    dplyr::mutate(model = label,
                  estimate  = round(estimate, 3),
                  std.error = round(std.error, 3),
                  conf.low  = round(conf.low, 3),
                  conf.high = round(conf.high, 3),
                  p.value   = signif(p.value, 3)) |>
    dplyr::select(model, term, estimate, std.error, conf.low, conf.high, p.value)
}

# ggpredict outputs columns based on terms order:
#   x = 1st term
#   "group" column = 2nd term (literal column name)
#   "facet" column = 3rd term (literal column name)
# We use `kind` to specify which case we're handling:
#   "q1q2": terms = c("phase",      "group",     "verb_match") → x=phase, group=L1/L2,    facet=match
#   "q3":   terms = c("verb_stress","verb_match")              → x=stress, group=match,   no facet
#   "q4":   terms = c("verb_stress","verb_match","group")      → x=stress, group=match,   facet=L1/L2
build_cost <- function(pred_data, type, factor_label, kind) {
  df <- as.data.frame(pred_data)
  
  if (kind == "q1q2") {
    df <- df |>
      dplyr::rename(level = x, group = group, match = facet, pred = predicted)
  } else if (kind == "q3") {
    df <- df |>
      dplyr::rename(level = x, match = group, pred = predicted) |>
      dplyr::mutate(group = NA_character_)
  } else if (kind == "q4") {
    df <- df |>
      dplyr::rename(level = x, match = group, group = facet, pred = predicted)
  }
  
  df$match <- as.character(df$match)
  df$group <- as.character(df$group)
  
  if (type == "rt") {
    df <- df |> dplyr::mutate(value = (1/pred) * 1000)
  } else if (type == "acc") {
    df <- df |> dplyr::mutate(value = pred * 100)
  }
  
  out <- df |>
    dplyr::select(group, level, match, value) |>
    tidyr::pivot_wider(names_from = match, values_from = value)
  
  if (!all(c("Match", "Mismatch") %in% names(out))) {
    stop("build_cost: pivot did not produce 'Match' and 'Mismatch' columns. Got: ",
         paste(names(out), collapse = ", "),
         ". Check ggpredict() output and the `kind` argument.")
  }
  
  if (type == "rt") {
    out <- out |> dplyr::mutate(cost = Mismatch - Match)
  } else if (type == "acc") {
    out <- out |> dplyr::mutate(cost = Match - Mismatch)
  }
  
  out |>
    dplyr::mutate(factor = factor_label,
                  measure = type) |>
    dplyr::select(factor, measure, group, level, Match, Mismatch, cost)
}


