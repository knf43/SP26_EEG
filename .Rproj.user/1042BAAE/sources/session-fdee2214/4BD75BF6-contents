# --- Helper: predicted RT/acc by phase × group × match ---
make_pred_acc_plot <- function(pred_data, title_text) {
  ggplot(as.data.frame(pred_data),
         aes(x = x, y = predicted, colour = facet, group = facet)) +
    geom_pointrange(aes(ymin = conf.low, ymax = conf.high),
                    position = position_dodge(0.2), size = 0.7) +
    geom_line(position = position_dodge(0.2), linewidth = 0.8) +
    facet_wrap(~ group) +
    coord_cartesian(ylim = c(0.85, 1.00)) +
    scale_y_continuous(labels = scales::percent_format(accuracy = 1)) +
    labs(title = title_text, x = "Phase", y = "Predicted P(correct)", colour = NULL)
}
make_pred_rt_plot <- function(pred_data, title_text) {
  ggplot(as.data.frame(pred_data),
         aes(x = x, y = (1/predicted) * 1000, colour = facet, group = facet)) +
    geom_pointrange(aes(ymin = (1/conf.high) * 1000, ymax = (1/conf.low) * 1000),
                    position = position_dodge(0.2), size = 0.7) +
    geom_line(position = position_dodge(0.2), linewidth = 0.8) +
    facet_wrap(~ group) +
    labs(title = title_text, x = "Phase", y = "Predicted RT (ms)", colour = NULL)
}

