# --- Two-step participant summary helper ---
# Average within participant first, then across participants per group
summarize_factor <- function(data, factor_var) {
  factor_sym <- rlang::sym(factor_var)
  by_p <- data |>
    dplyr::group_by(participant, group, phase, !!factor_sym) |>
    dplyr::summarise(
      accuracy   = mean(corr, na.rm = TRUE),
      rt_correct = mean(rt_correct, na.rm = TRUE),
      n_trials   = dplyr::n(),
      .groups    = "drop"
    )
  by_p |>
    dplyr::group_by(group, phase, !!factor_sym) |>
    dplyr::summarise(
      mean_acc = mean(accuracy, na.rm = TRUE),
      se_acc   = sd(accuracy, na.rm = TRUE) / sqrt(dplyr::n()),
      mean_rt  = mean(rt_correct, na.rm = TRUE),
      se_rt    = sd(rt_correct, na.rm = TRUE) / sqrt(dplyr::n()),
      n_participants = dplyr::n(),
      .groups  = "drop"
    )
}

