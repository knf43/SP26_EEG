# --- Mismatch cost: difference between mismatch and match ---
# This is the "surprise" effect — what we care about theoretically
mismatch_cost <- function(data, factor_var) {
  factor_sym <- rlang::sym(factor_var)
  by_p <- data |>
    dplyr::group_by(participant, group, phase, !!factor_sym) |>
    dplyr::summarise(
      accuracy   = mean(corr, na.rm = TRUE),
      rt_correct = mean(rt_correct, na.rm = TRUE),
      .groups    = "drop"
    ) |>
    tidyr::pivot_wider(names_from = !!factor_sym,
                       values_from = c(accuracy, rt_correct))
  by_p |>
    dplyr::mutate(
      acc_cost = accuracy_Match - accuracy_Mismatch,    # positive = mismatch hurt accuracy
      rt_cost  = rt_correct_Mismatch - rt_correct_Match # positive = mismatch slowed RT
    ) |>
    dplyr::group_by(group, phase) |>
    dplyr::summarise(
      mean_acc_cost = mean(acc_cost, na.rm = TRUE),
      se_acc_cost   = sd(acc_cost, na.rm = TRUE) / sqrt(dplyr::n()),
      mean_rt_cost  = mean(rt_cost, na.rm = TRUE) * 1000,  # ms
      se_rt_cost    = sd(rt_cost, na.rm = TRUE) / sqrt(dplyr::n()) * 1000,
      .groups       = "drop"
    )
}

