kable(overall,
      caption = "Mean accuracy and reaction time (correct, incorrect, all trials) by group and phase.",
      align = c("l", "l", "r", "r", "r", "r", "r", "r"))
```

```{r overall-prose, results='asis'}
make_phase_line <- function(grp_label, grp_code) {
  rows <- by_grp |> filter(group == grp_code) |> arrange(phase)
  pre  <- rows |> filter(phase == "pre")
  post <- rows |> filter(phase == "post")
  trn  <- rows |> filter(phase == "training")

  parts <- c()
  if (nrow(pre) > 0)
    parts <- c(parts, sprintf("pre-test (*M* = %s, RT~correct~ = %s)",
                              fmt_pct(pre$accuracy), fmt_rt(pre$rt_correct)))
  if (nrow(trn) > 0)
    parts <- c(parts, sprintf("training (*M* = %s, RT~correct~ = %s)",
                              fmt_pct(trn$accuracy), fmt_rt(trn$rt_correct)))
  if (nrow(post) > 0)
    parts <- c(parts, sprintf("post-test (*M* = %s, RT~correct~ = %s)",
                              fmt_pct(post$accuracy), fmt_rt(post$rt_correct)))

  sprintf("%s speakers showed accuracy at %s.",
          grp_label, paste(parts, collapse = ", "))
}

cat(make_phase_line("L1 Spanish", "L1"), "\n\n")
if (n_l2 > 0) cat(make_phase_line("L2 Spanish", "L2"), "\n\n")

change_tbl <- by_grp |>
  filter(phase %in% c("pre", "post")) |>
  select(group, phase, accuracy, rt_correct) |>
  pivot_wider(names_from = phase, values_from = c(accuracy, rt_correct)) |>
  mutate(
    acc_change = accuracy_post - accuracy_pre,
    rt_change  = rt_correct_post - rt_correct_pre
  )

for (g in change_tbl$group) {
  row <- change_tbl |> filter(group == g)
  cat(sprintf(
    "From pre- to post-test, %s speakers showed an accuracy change of %+.1f percentage points and a correct-trial RT change of %+d ms.\n\n",
    g, 100 * row$acc_change, round(1000 * row$rt_change)
  ))
}
```

