```

## Performance by Verb Stress and Suffix Tense

```{r condition-table}
cond_tbl <- summary_group(long, c("verb_stress", "suffix_tense")) |>
  filter(phase %in% c("pre", "post"),
         !is.na(verb_stress), !is.na(suffix_tense)) |>
  mutate(
    Accuracy = fmt_pct(accuracy),
    RT       = fmt_rt(rt),
    Phase    = stringr::str_to_title(as.character(phase)),
    Stress   = stringr::str_to_title(verb_stress),
    Tense    = stringr::str_to_title(suffix_tense)
  ) |>
  select(Group = group, Phase, `Verb Stress` = Stress,
         `Suffix Tense` = Tense, Accuracy, `RT (correct)` = RT)

kable(cond_tbl,
      caption = "Accuracy and reaction time by group, phase, and condition.",
      align = c("l", "l", "l", "l", "r", "r"))
```

```{r fig3, fig.cap="Accuracy (left) and reaction time (right) at pre- and post-test, broken down by verb stress (paroxytone vs. oxytone) and suffix tense (present vs. past), separately for each group."}
knitr::include_graphics("behavioral_output/fig3_condition_breakdown.png")
```

## Training Phase

```{r training-table}
train_tbl <- summary_group(filter(long, phase == "training"),
                           c("stress_unstress", "present_past")) |>
  filter(!is.na(stress_unstress), !is.na(present_past)) |>
  mutate(
    Accuracy = fmt_pct(accuracy),
    RT       = fmt_rt(rt),
    Stress   = stress_unstress,
    Tense    = stringr::str_to_title(present_past)
  ) |>
  select(Group = group, Stress, Tense, Accuracy, `RT (correct)` = RT)

kable(train_tbl,
      caption = "Training phase accuracy and reaction time by group and condition.",
      align = c("l", "l", "l", "r", "r"))
```

```{r training-prose, results='asis'}
train_by_grp <- by_grp |> filter(phase == "training")
for (i in seq_len(nrow(train_by_grp))) {
  row <- train_by_grp[i, ]
  cat(sprintf(
    "During training, %s speakers reached an overall accuracy of %s (RT = %s on correct trials).\n\n",
    row$group, fmt_pct(row$accuracy), fmt_rt(row$rt)
  ))
}
```

